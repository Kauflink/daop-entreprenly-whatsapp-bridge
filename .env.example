# Copia este archivo como .env y ajusta los valores.

# URLs base de los dos backends del chatbot. Solo el backend con el "turno"
# activo recibe y responde los mensajes (se cambia desde la pagina /switch).
BACKEND_URL_DAOP=https://daop-api.entreprenly.online/api/v1
BACKEND_URL_AP=https://ap-api.entreprenly.online/api/v1

# Backend que arranca con el turno (daop | ap).
DEFAULT_BACKEND=daop

# Token compartido que protege los endpoints /bridge del backend.
# DEBE COINCIDIR con chatbot.whatsapp.bridge-token del backend.
BRIDGE_TOKEN=entreprenly-bridge-secret

# Clave que protege la pagina /switch. Si no se define, usa BRIDGE_TOKEN.
# Abre la pagina como: https://switch.entreprenly.online/switch?key=<SWITCH_TOKEN>
SWITCH_TOKEN=cambia-esta-clave

# Id del vendedor (tu usuario) al que pertenece la sesion de WhatsApp.
SELLER_ID=1

# Email del vendedor (para resolver el catalogo correcto).
OWNER_EMAIL=tu@email.com

# Nombre del negocio que se mostrara en la app.
BUSINESS_NAME=Mi Bodega

# Puerto local del puente (la pagina con el QR se abre aqui).
PORT=3001
